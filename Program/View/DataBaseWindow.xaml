<Window x:Class="Program.View.DataBaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Program.View"
        DataContext="ViewModel/DataBaseViewModel.cs"
        mc:Ignorable="d"
        Title="DataBaseWindow" Height="450" Width="800">
    <Grid>
        <Button Content="Back" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding ClickBack}"/>
        <Label Content="{Binding UserType}" HorizontalAlignment="Center" Margin="0,166,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
