<Window x:Class="Program.View.SignInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Program.View" 
        mc:Ignorable="d"
        Title="SignInWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <StackPanel Width="400" Orientation="Vertical" Margin="0,50,400,0">
                <Label Content="Login"/>
                <TextBox x:Name="emailTextBox" Text="{Binding User.Email}"/>
                <TextBox x:Name="passTextBox" Text="{Binding User.Password}"/>
                <Button x:Name="signInButton" Content="Sign In" Command="{Binding ClickSignIn}"/>
                <Button x:Name="signUpButton" Content="Sign Up" Command="{Binding ClickSignUp}"/>
                <Button x:Name="guest" Content="Guest" Command="{Binding ClickGuest}"/>
                <Button x:Name="exit" Content="Exit" Command="{Binding ClickExit}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
